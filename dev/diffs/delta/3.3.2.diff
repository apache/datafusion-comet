index 0000000..5aa5294
--- /dev/null
+++ b/icebergShaded/iceberg_src_patches/0006-allow-jdk17-plus.patch
@@ -0,0 +1,17 @@
+diff --git a/build.gradle b/build.gradle
+index 12ed701..d8ae24d 100644
+--- a/build.gradle
++++ b/build.gradle
+@@ -58,8 +58,11 @@ if (JavaVersion.current() == JavaVersion.VERSION_1_8) {
+   project.ext.jdkVersion = '8'
+ } else if (JavaVersion.current() == JavaVersion.VERSION_11) {
+   project.ext.jdkVersion = '11'
++} else if (JavaVersion.current().majorVersion.toInteger() >= 17) {
++  // Allow JDK 17+ for the Comet Delta regression suite.
++  project.ext.jdkVersion = '11'
+ } else {
+-  throw new GradleException("This build must be run with JDK 8 or 11 but was executed with JDK " + JavaVersion.current())
++  throw new GradleException("This build must be run with JDK 8, 11, or 17+ but was executed with JDK " + JavaVersion.current())
+ }
+ 
